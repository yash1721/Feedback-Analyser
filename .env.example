APP_NAME=FeedbackIQ
ENVIRONMENT=local
DEBUG=false
API_V1_PREFIX=/api/v1
SERVICE_NAME=FeedbackIQ
LOG_LEVEL=INFO
LOG_FORMAT=plain
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
REQUEST_TIMEOUT_SECONDS=10
MAX_IMAGE_BYTES=5242880
MAX_PDF_BYTES=10485760
MAX_CSV_BYTES=2097152
OCR_LANGUAGES=eng+hin
TESSERACT_TIMEOUT_SECONDS=5
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
SENTIMENT_MODEL_NAME=distilbert-base-uncased-finetuned-sst-2-english
RETRIEVAL_TOP_K=3
DATABASE_URL=postgresql+psycopg://feedbackiq:feedbackiq@localhost:5432/feedbackiq
TEST_DATABASE_URL=sqlite+pysqlite:///:memory:
LOCAL_STORAGE_DIR=.local_storage
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
PROCESSING_MAX_RETRIES=3
PROCESSING_RETRY_BACKOFF_SECONDS=5
CELERY_TASK_ALWAYS_EAGER=false
VECTOR_PROVIDER=qdrant
EMBEDDING_PROVIDER=bge_m3
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=feedbackiq_knowledge
VECTOR_SIZE=1024
VECTOR_DISTANCE=cosine
KNOWLEDGE_CHUNK_SIZE_CHARS=1200
KNOWLEDGE_CHUNK_OVERLAP_CHARS=200
LLM_PROVIDER=rule_based
LLM_FALLBACK_PROVIDER=rule_based
LLM_MODEL_NAME=rule-based-feedback-analyzer-v1
LLM_PROMPT_VERSION=feedback-analysis-v1
LLM_CONFIDENCE_THRESHOLD=0.5
WORKFLOW_LOW_CONFIDENCE_THRESHOLD=0.65
WORKFLOW_DEFAULT_SLA_HOURS=48
WORKFLOW_P0_SLA_HOURS=4
WORKFLOW_P1_SLA_HOURS=12
WORKFLOW_AUTO_CREATE_TICKETS=false
NOTIFICATION_PROVIDER=log
EVALUATION_REPORT_DIR=eval_reports
AUTH_ENABLED=false
API_KEYS=local-admin-key:admin
METRICS_AUTH_REQUIRED=false
READY_AUTH_REQUIRED=false
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS_PER_MINUTE=120
RATE_LIMIT_BURST=30
PII_REDACTION_ENABLED=true
PII_STORE_RAW_TEXT=true
PII_ANALYSIS_USES_REDACTED_TEXT=true
PII_REDACTION_MODE=mask
PROMPT_INJECTION_DETECTION_ENABLED=true
PROMPT_INJECTION_MODE=warn
